# Create an X developer app and set its OAuth 2.0 client ID here.
# The callback URL must match the one configured in the app.
X_CLIENT_ID=
# Optional. Some X apps are configured as confidential clients and require this.
X_CLIENT_SECRET=
X_REDIRECT_URI=http://127.0.0.1:8765/callback

# Optional. Defaults shown here.
PKB_DATA_DIR=data
PKB_THREAD_SEARCH=all
